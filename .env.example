# Local project selection
# Prefer PROJECT_DIR when using base_data/<PROJECT_DIR>/...
PROJECT_NAME=
PROJECT_DIR=ACI

# Result persistence
# When true, heal/diagnose/audit results are written to result_data/
PERSIST_RESULTS=false

# Heal behavior
# Supported values: sectioned, bundled
HEAL_MODE=sectioned

# ReadMe integration
README_API_KEY=
README_BRANCH=stable

# Optional explicit file overrides
# Leave blank to auto-resolve from base_data/ or base_data/<PROJECT_DIR>/
SPEC_PATH=
DOCS_PATH=
GLOSSARY_PATH=
AUDIT_FIXTURE_PATH=
RECIPES_PATH=

# Redaction controls
# Comma-separated regex patterns. Leave blank to use built-in defaults.
REDACT_PATTERNS=

# Comma-separated regex allowlist that bypasses redaction
REDACT_ALLOWLIST=

# ReadMe push behavior
# When true, allow creating categories during push flows
ALLOW_CATEGORY_CREATE=false

# Notes
# In https://dash.readme.com/project/doc-healer/v1.0/labs, "GraphQL" feature was ENABLED
# See: https://docs.readme.com/main/docs/graphql